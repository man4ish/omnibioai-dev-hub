# Path to the directory that contains all omnibioai-* repo clones.
# build_index.py reads this to locate source documentation for indexing.
#
# Local development (repos cloned under ~/Desktop/machine/):
REPO_BASE=/home/manish/Desktop/machine
#
# Docker (repos mounted as a volume at /repos):
# REPO_BASE=/repos
#
# Ollama API base URL (default assumes Docker service named "ollama"):
# OLLAMA_URL=http://ollama:11434/api
